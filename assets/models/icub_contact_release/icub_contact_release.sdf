        <p_gain>50</p_gain>
        <i_gain>7</i_gain>
        <d_gain>0.1</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>l_shoulder_pitch</joint_name>
        <topic_name>/grasp_demo/l_shoulder_pitch</topic_name>
        <p_gain>100</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>-0.52</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>l_shoulder_roll</joint_name>
        <topic_name>/grasp_demo/l_shoulder_roll</topic_name>
        <p_gain>100</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0.52</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>l_shoulder_yaw</joint_name>
        <topic_name>/grasp_demo/l_shoulder_yaw</topic_name>
        <p_gain>100</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>l_elbow</joint_name>
        <topic_name>/grasp_demo/l_elbow</topic_name>
        <p_gain>100</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0.785</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>l_wrist_prosup</joint_name>
        <topic_name>/grasp_demo/l_wrist_prosup</topic_name>
        <p_gain>100</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
