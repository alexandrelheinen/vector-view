        <topic_name>/grasp_demo/r_ankle_roll</topic_name>
        <p_gain>1000</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>torso_yaw</joint_name>
        <topic_name>/grasp_demo/torso_yaw</topic_name>
        <p_gain>100</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>torso_roll</joint_name>
        <topic_name>/grasp_demo/torso_roll</topic_name>
        <p_gain>100</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>torso_pitch</joint_name>
        <topic_name>/grasp_demo/torso_pitch</topic_name>
        <p_gain>100</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>neck_pitch</joint_name>
        <topic_name>/grasp_demo/neck_pitch</topic_name>
        <p_gain>50</p_gain>
        <i_gain>7</i_gain>
        <d_gain>0.1</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>neck_roll</joint_name>
        <topic_name>/grasp_demo/neck_roll</topic_name>
        <p_gain>50</p_gain>
