<?xml version='1.0'?>
<!--
  Release-demo variant of icub_contact: JointPositionController plugins mirror the
  original gazebo_yarp_controlboard PIDs so the robot holds a stable standing pose
  before the scripted arm grasp sequence runs.
-->
<sdf version='1.4'>
  <model name="iCub_fixed">
    <include>
      <uri>model://icub</uri>
      <pose>0.0 0 1.0 0 0 3.14</pose>


      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>l_hip_pitch</joint_name>
        <topic_name>/grasp_demo/l_hip_pitch</topic_name>
        <p_gain>1000</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>l_hip_roll</joint_name>
        <topic_name>/grasp_demo/l_hip_roll</topic_name>
        <p_gain>1000</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>l_hip_yaw</joint_name>
        <topic_name>/grasp_demo/l_hip_yaw</topic_name>
        <p_gain>1000</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>l_knee</joint_name>
        <topic_name>/grasp_demo/l_knee</topic_name>
        <p_gain>1000</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>l_ankle_pitch</joint_name>
        <topic_name>/grasp_demo/l_ankle_pitch</topic_name>
        <p_gain>1000</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>l_ankle_roll</joint_name>
        <topic_name>/grasp_demo/l_ankle_roll</topic_name>
        <p_gain>1000</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>r_hip_pitch</joint_name>
        <topic_name>/grasp_demo/r_hip_pitch</topic_name>
        <p_gain>1000</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>r_hip_roll</joint_name>
        <topic_name>/grasp_demo/r_hip_roll</topic_name>
        <p_gain>1000</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>r_hip_yaw</joint_name>
        <topic_name>/grasp_demo/r_hip_yaw</topic_name>
        <p_gain>1000</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>r_knee</joint_name>
        <topic_name>/grasp_demo/r_knee</topic_name>
        <p_gain>1000</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>r_ankle_pitch</joint_name>
        <topic_name>/grasp_demo/r_ankle_pitch</topic_name>
        <p_gain>1000</p_gain>
        <i_gain>10</i_gain>
        <d_gain>10</d_gain>
        <initial_position>0</initial_position>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
