# Copy to .env and adjust paths for your machine:
#   cp .env.example .env
#
# scripts/run.sh loads this file automatically when present.

# Repository root (defaults to the directory above scripts/ when unset)
# VECTOR_VIEW=/home/you/Workspace/vector-view

# Optional: path to codyco-superbuild install used by the demo controller
# CODYCO_SUPERBUILD_ROOT=/home/you/Workspace/codyco-superbuild

# Optional overrides for VectorGUI short-name topic building
# VECTORVIEW_WORLD=default
# VECTORVIEW_MODEL_INSTANCE=iCub_fixed
# VECTORVIEW_ROBOT_MODEL=iCub
